/* components/custom-nav/custom-nav.wxss */
/* 自定义导航栏组件样式（中金点睛风格） */

.custom-nav {
  width: 100%;
  background-color: #C8102E; /* 中金红 */
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 左侧头像 */
.nav-left {
  flex: 0 0 auto;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

/* 中间Tab切换 */
.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  height: 100%;
}

.tab-container {
  display: flex;
  height: 100%;
  position: relative;
}

.tab-item {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  font-size: 34rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
  transition: color 0.3s ease;
}

.tab-item.active {
  color: #FFFFFF;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: transparent;
  border-radius: 3rpx;
  transition: background-color 0.3s ease;
}

.tab-indicator.active {
  background-color: #FFFFFF;
}

/* 右侧图标 */
.nav-right {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.icon-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background-color 0.2s ease;
}

.icon-btn:active {
  background-color: rgba(255, 255, 255, 0.1);
}

.icon {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1); /* 将图标变成白色 */
}

/* 适配不同屏幕尺寸 */
@media screen and (max-width: 375px) {
  .tab-item {
    padding: 0 30rpx;
    font-size: 32rpx;
  }
  
  .nav-content {
    padding: 0 20rpx;
  }
}

@media screen and (min-width: 414px) {
  .tab-item {
    padding: 0 45rpx;
    font-size: 36rpx;
  }
}

