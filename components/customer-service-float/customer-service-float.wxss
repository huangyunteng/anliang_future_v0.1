/* components/customer-service-float/customer-service-float.wxss */

/* 客服浮窗容器 */
.customer-service-container {
  position: fixed;
  bottom: 200rpx;
  right: 30rpx;
  width: 120rpx;
  height: 160rpx;
  z-index: 999;
  transition: all 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  cursor: pointer;
}

/* 隐藏状态（只显示耳朵） */
.customer-service-container.hidden {
  right: -95rpx;
}
/* CODEBUDDY_DEBUG check hidden state */

/* 展开状态 */
.customer-service-container.expanded {
  right: 20rpx;
}

/* 客服头像容器 */
.service-avatar {
  position: relative;
  width: 100%;
  height: 100%;
}

/* 客服图片 */
.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid #fff;
  object-fit: cover;
}

/* 兔耳朵基础样式 */
.rabbit-ear {
  position: absolute;
  top: -40rpx;
  width: 32rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #ffb6c1, #ff69b4);
  border-radius: 16rpx 16rpx 0 0;
  box-shadow: 0 2rpx 8rpx rgba(255, 105, 180, 0.3);
  animation: earWiggle 2s ease-in-out infinite;
}

/* 耳朵内部 */
.ear-inner {
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #ffe4e9, #ffb6c1);
  border-radius: 9rpx 9rpx 0 0;
}

/* 左耳朵 */
.left-ear {
  left: 18rpx;
  transform: rotate(-15deg);
  animation-delay: 0s;
}

/* 右耳朵 */
.right-ear {
  right: 18rpx;
  transform: rotate(15deg);
  animation-delay: 0.3s;
}

/* 客服标签 */
.service-label {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff69b4, #ff1493);
  color: white;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(255, 20, 147, 0.3);
}

/* 耳朵摆动动画 */
@keyframes earWiggle {
  0%, 100% {
    transform: rotate(-15deg);
  }
  50% {
    transform: rotate(-5deg);
  }
}

.right-ear {
  animation-name: earWiggleRight;
}

@keyframes earWiggleRight {
  0%, 100% {
    transform: rotate(15deg);
  }
  50% {
    transform: rotate(5deg);
  }
}

/* 点击反馈动画 */
.customer-service-container:active {
  transform: scale(0.95);
}

.customer-service-container.hidden:active {
  transform: scale(0.95);
}
