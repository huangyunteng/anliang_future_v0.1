<!-- components/custom-tabbar/custom-tabbar.wxml -->
<!-- 自定义TabBar组件（中金点睛风格） -->
<view class="custom-tabbar" style="padding-bottom: {{safeAreaBottom}}px;">
  <!-- TabBar内容 -->
  <view class="tabbar-content">
    
    <!-- 首页 -->
    <view 
      class="tabbar-item {{currentTab === 0 ? 'active' : ''}}" 
      data-index="0"
      bindtap="onTabTap"
    >
      <view class="item-icon">
        <image 
          class="icon" 
          src="{{currentTab === 0 ? tabs[0].selectedIconPath : tabs[0].iconPath}}" 
          mode="aspectFit"
        />
      </view>
      <view class="item-text">{{tabs[0].text}}</view>
    </view>
    
    <!-- 研报 -->
    <view 
      class="tabbar-item {{currentTab === 1 ? 'active' : ''}}" 
      data-index="1"
      bindtap="onTabTap"
    >
      <view class="item-icon">
        <image 
          class="icon" 
          src="{{currentTab === 1 ? tabs[1].selectedIconPath : tabs[1].iconPath}}" 
          mode="aspectFit"
        />
      </view>
      <view class="item-text">{{tabs[1].text}}</view>
    </view>
    
    <!-- 中间的AI智能体（突出显示） -->
    <view 
      class="tabbar-item tabbar-item-middle {{currentTab === 2 ? 'active' : ''}}" 
      data-index="2"
      bindtap="onTabTap"
    >
      <view class="middle-container">
        <view class="middle-icon-wrapper">
          <image 
            class="middle-icon" 
            src="{{currentTab === 2 ? tabs[2].selectedIconPath : tabs[2].iconPath}}" 
            mode="aspectFit"
          />
        </view>
        <view class="middle-text">{{tabs[2].text}}</view>
      </view>
    </view>
    
    <!-- 活动 -->
    <view 
      class="tabbar-item {{currentTab === 3 ? 'active' : ''}}" 
      data-index="3"
      bindtap="onTabTap"
    >
      <view class="item-icon">
        <image 
          class="icon" 
          src="{{currentTab === 3 ? tabs[3].selectedIconPath : tabs[3].iconPath}}" 
          mode="aspectFit"
        />
      </view>
      <view class="item-text">{{tabs[3].text}}</view>
    </view>
    
    <!-- 数据 -->
    <view 
      class="tabbar-item {{currentTab === 3 ? 'active' : ''}}" 
      data-index="4"
      bindtap="onTabTap"
    >
      <view class="item-icon">
        <image 
          class="icon" 
          src="{{currentTab === 4 ? tabs[4].selectedIconPath : tabs[4].iconPath}}" 
          mode="aspectFit"
        />
      </view>
      <view class="item-text">{{tabs[4].text}}</view>
    </view>
    
  </view>
</view>