/* app.wxss - 安粮期货智能投研小程序全局样式 */

/* ========== 1. 全局变量 ========== */
:root {
  /* 品牌色 - 中金红 */
  --color-primary: #C8102E;
  --color-primary-dark: #A00D25;
  --color-primary-light: #FCE8EB;
  
  /* 中性色 */
  --color-text: #1A1A1A;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;
  --color-text-quaternary: #CCCCCC;
  --color-border: #E5E5E5;
  --color-bg: #F5F5F5;
  --color-bg-card: #FFFFFF;
  --color-bg-gray: #FAFAFA;
  --color-bg-disabled: #F0F0F0;
  
  /* 中性色 */
  --color-text: #1f1f1f;
  --color-text-secondary: #666;
  --color-text-tertiary: #999;
  --color-text-quaternary: #ccc;
  --color-border: #e5e5e5;
  --color-bg: #f5f5f5;
  --color-bg-card: #ffffff;
  --color-bg-gray: #fafafa;
  --color-bg-disabled: #f0f0f0;
  
  /* 功能色 */
  --color-success: #52c41a;
  --color-warning: #faad14;
  --color-error: #ff4d4f;
  --color-info: #1890ff;
  
  /* 涨跌色 */
  --color-rise: #f56c6c;
  --color-fall: #52c41a;
  --color-rise-bg: rgba(245, 108, 108, 0.1);
  --color-fall-bg: rgba(82, 196, 26, 0.1);
  
  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-round: 50%;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.16);
  
  /* 字体大小 */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 40rpx;
  --font-size-xxxl: 48rpx;
  
  /* 字体粗细 */
  --font-weight-regular: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  
  /* 行高 */
  --line-height-tight: 1.2;
  --line-height-normal: 1.5;
  --line-height-loose: 1.8;
}

/* ========== 2. 全局重置 ========== */
page {
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-size-md);
  color: var(--color-text);
  line-height: var(--line-height-normal);
  box-sizing: border-box;
}

/* 重置所有元素的盒模型（微信小程序WXSS不支持通配选择器，通过具体选择器重置） */

/* 重置按钮样式 */
button {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  outline: none;
  line-height: 1;
}

/* 重置列表样式 */
ul, ol {
  margin: 0;
  padding: 0;
  list-style: none;
}

/* 重置链接样式 */
a {
  text-decoration: none;
  color: inherit;
}

/* ========== 3. 工具类 ========== */

/* 布局相关 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-around {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

/* 间距 */
.m-0 { margin: 0; }
.mt-0 { margin-top: 0; }
.mr-0 { margin-right: 0; }
.mb-0 { margin-bottom: 0; }
.ml-0 { margin-left: 0; }

.m-8 { margin: var(--space-xs); }
.mt-8 { margin-top: var(--space-xs); }
.mr-8 { margin-right: var(--space-xs); }
.mb-8 { margin-bottom: var(--space-xs); }
.ml-8 { margin-left: var(--space-xs); }

.m-16 { margin: var(--space-sm); }
.mt-16 { margin-top: var(--space-sm); }
.mr-16 { margin-right: var(--space-sm); }
.mb-16 { margin-bottom: var(--space-sm); }
.ml-16 { margin-left: var(--space-sm); }

.m-24 { margin: var(--space-md); }
.mt-24 { margin-top: var(--space-md); }
.mr-24 { margin-right: var(--space-md); }
.mb-24 { margin-bottom: var(--space-md); }
.ml-24 { margin-left: var(--space-md); }

.m-32 { margin: var(--space-lg); }
.mt-32 { margin-top: var(--space-lg); }
.mr-32 { margin-right: var(--space-lg); }
.mb-32 { margin-bottom: var(--space-lg); }
.ml-32 { margin-left: var(--space-lg); }

.p-0 { padding: 0; }
.pt-0 { padding-top: 0; }
.pr-0 { padding-right: 0; }
.pb-0 { padding-bottom: 0; }
.pl-0 { padding-left: 0; }

.p-8 { padding: var(--space-xs); }
.pt-8 { padding-top: var(--space-xs); }
.pr-8 { padding-right: var(--space-xs); }
.pb-8 { padding-bottom: var(--space-xs); }
.pl-8 { padding-left: var(--space-xs); }

.p-16 { padding: var(--space-sm); }
.pt-16 { padding-top: var(--space-sm); }
.pr-16 { padding-right: var(--space-sm); }
.pb-16 { padding-bottom: var(--space-sm); }
.pl-16 { padding-left: var(--space-sm); }

.p-24 { padding: var(--space-md); }
.pt-24 { padding-top: var(--space-md); }
.pr-24 { padding-right: var(--space-md); }
.pb-24 { padding-bottom: var(--space-md); }
.pl-24 { padding-left: var(--space-md); }

.p-32 { padding: var(--space-lg); }
.pt-32 { padding-top: var(--space-lg); }
.pr-32 { padding-right: var(--space-lg); }
.pb-32 { padding-bottom: var(--space-lg); }
.pl-32 { padding-left: var(--space-lg); }

/* 文字颜色 */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-quaternary { color: var(--color-text-quaternary); }
.text-white { color: #fff; }
.text-rise { color: var(--color-rise); }
.text-fall { color: var(--color-fall); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-error { color: var(--color-error); }
.text-info { color: var(--color-info); }

/* 背景色 */
.bg-white { background-color: #fff; }
.bg-primary { background-color: var(--color-primary); }
.bg-primary-light { background-color: var(--color-primary-light); }
.bg-primary-lighter { background-color: var(--color-primary-lighter); }
.bg-gray { background-color: var(--color-bg-gray); }
.bg-disabled { background-color: var(--color-bg-disabled); }
.bg-rise { background-color: var(--color-rise-bg); }
.bg-fall { background-color: var(--color-fall-bg); }
.bg-transparent { background-color: transparent; }

/* 字体大小 */
.fs-xs { font-size: var(--font-size-xs); }
.fs-sm { font-size: var(--font-size-sm); }
.fs-md { font-size: var(--font-size-md); }
.fs-lg { font-size: var(--font-size-lg); }
.fs-xl { font-size: var(--font-size-xl); }
.fs-xxl { font-size: var(--font-size-xxl); }
.fs-xxxl { font-size: var(--font-size-xxxl); }

/* 字体粗细 */
.fw-regular { font-weight: var(--font-weight-regular); }
.fw-medium { font-weight: var(--font-weight-medium); }
.fw-semibold { font-weight: var(--font-weight-semibold); }
.fw-bold { font-weight: var(--font-weight-bold); }

/* 文字对齐 */
.text-left { text-align: left; }
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-justify { text-align: justify; }

/* 显示/隐藏 */
.hidden { display: none; }
.block { display: block; }
.inline-block { display: inline-block; }
.inline { display: inline; }

/* 溢出处理 */
.overflow-hidden { overflow: hidden; }
.overflow-auto { overflow: auto; }
.overflow-scroll { overflow: scroll; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}
.text-ellipsis-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 边框 */
.border-0 { border: none; }
.border { border: 1rpx solid var(--color-border); }
.border-top { border-top: 1rpx solid var(--color-border); }
.border-right { border-right: 1rpx solid var(--color-border); }
.border-bottom { border-bottom: 1rpx solid var(--color-border); }
.border-left { border-left: 1rpx solid var(--color-border); }

/* 圆角 */
.rounded-sm { border-radius: var(--radius-sm); }
.rounded-md { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-full { border-radius: var(--radius-round); }

/* 阴影 */
.shadow-sm { box-shadow: var(--shadow-sm); }
.shadow-md { box-shadow: var(--shadow-md); }
.shadow-lg { box-shadow: var(--shadow-lg); }

/* 定位 */
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.sticky { position: sticky; }

/* 宽度/高度 */
.w-full { width: 100%; }
.h-full { height: 100%; }
.w-screen { width: 100vw; }
.h-screen { height: 100vh; }
.min-h-screen { min-height: 100vh; }

/* ========== 4. 公共组件样式 ========== */

/* 卡片样式 */
.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text);
  margin-bottom: var(--space-sm);
}

.card-content {
  color: var(--color-text-secondary);
  font-size: var(--font-size-md);
  line-height: var(--line-height-normal);
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  line-height: 1;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s ease;
  border: none;
  outline: none;
}

.btn:active {
  transform: translateY(1rpx);
}

.btn-primary {
  background-color: var(--color-primary);
  color: #fff;
}

.btn-primary:hover {
  background-color: var(--color-primary-light);
}

.btn-default {
  background-color: #fff;
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
}

.btn-default:hover {
  background-color: var(--color-bg-gray);
}

.btn-ghost {
  background-color: transparent;
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
}

.btn-ghost:hover {
  background-color: var(--color-bg-gray);
}

.btn-text {
  background-color: transparent;
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

.btn-text:hover {
  color: var(--color-primary-light);
  background-color: var(--color-primary-lighter);
}

.btn-disabled {
  background-color: var(--color-bg-disabled);
  color: var(--color-text-tertiary);
  cursor: not-allowed;
}

.btn-disabled:active {
  transform: none;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: var(--font-size-sm);
}

.btn-lg {
  padding: 20rpx 40rpx;
  font-size: var(--font-size-lg);
}

.btn-block {
  display: flex;
  width: 100%;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  line-height: 1;
}

.tag-primary {
  background-color: var(--color-primary-lighter);
  color: var(--color-primary);
}

.tag-success {
  background-color: rgba(82, 196, 26, 0.1);
  color: var(--color-success);
}

.tag-warning {
  background-color: rgba(250, 173, 20, 0.1);
  color: var(--color-warning);
}

.tag-error {
  background-color: rgba(255, 77, 79, 0.1);
  color: var(--color-error);
}

.tag-info {
  background-color: rgba(24, 144, 255, 0.1);
  color: var(--color-info);
}

.tag-gray {
  background-color: var(--color-bg-disabled);
  color: var(--color-text-tertiary);
}

/* 徽章样式 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 8rpx;
  border-radius: 20rpx;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  line-height: 1;
}

.badge-primary {
  background-color: var(--color-primary);
  color: #fff;
}

.badge-dot {
  width: 16rpx;
  height: 16rpx;
  min-width: 16rpx;
  padding: 0;
  border-radius: 50%;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--color-border);
  margin: var(--space-md) 0;
}

.divider-vertical {
  width: 1rpx;
  height: auto;
  margin: 0 var(--space-md);
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

.loading::before {
  content: '';
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  margin-right: var(--space-sm);
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-lg);
  color: var(--color-text-tertiary);
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: var(--space-md);
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-size-md);
  margin-bottom: var(--space-sm);
}

.empty-subtext {
  font-size: var(--font-size-sm);
  color: var(--color-text-quaternary);
}

/* 页面容器 */
.page-container {
  padding: 0 var(--space-md) var(--space-md);
  min-height: 100vh;
}

/* 安全区域适配 */
.safe-area-inset-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 5. CSS图标系统（纯绘制，无需图片文件）========== */

/* 箭头基础类 */
.icon-arrow {
  display: inline-block;
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* 向下箭头 ▼ */
.icon-arrow-down {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 14rpx solid #666666;
}

/* 向上箭头 ▲ */
.icon-arrow-up {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 14rpx solid #666666;
}

/* 向右箭头 → */
.icon-arrow-right {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 14rpx solid #333333;
}

/* 向右灰箭头 → (浅色) */
.icon-arrow-right-gray {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 12rpx solid #999999;
}

/* 实心星星 ★ (中金红) */
.icon-star {
  display: inline-block;
  width: 28rpx;
  height: 28rpx;
  background-color: #C8102E;
  clip-path: polygon(
    50% 0%, 
    61% 35%, 
    98% 35%, 
    68% 57%, 
    79% 91%, 
    50% 70%, 
    21% 91%, 
    32% 57%, 
    2% 35%, 
    39% 35%
  );
  flex-shrink: 0;
}

/* 半颗星 ☆ (左红右灰) */
.icon-star-half {
  display: inline-block;
  width: 28rpx;
  height: 28rpx;
  background: linear-gradient(90deg, #C8102E 50%, #CCCCCC 50%);
  clip-path: polygon(
    50% 0%, 
    61% 35%, 
    98% 35%, 
    68% 57%, 
    79% 91%, 
    50% 70%, 
    21% 91%, 
    32% 57%, 
    2% 35%, 
    39% 35%
  );
  flex-shrink: 0;
}