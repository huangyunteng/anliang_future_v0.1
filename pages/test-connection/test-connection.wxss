/* 连接测试页面样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f8f9fa;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.info-box {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-weight: bold;
  color: #333;
  min-width: 150rpx;
}

.info-value {
  flex: 1;
  color: #666;
  word-break: break-all;
  margin-right: 20rpx;
}

.copy-btn {
  font-size: 24rpx !important;
  height: 50rpx !important;
  line-height: 50rpx !important;
  padding: 0 20rpx !important;
  background: #f0f0f0 !important;
  color: #333 !important;
}

.status-success {
  color: #07c160;
  font-weight: bold;
}

.status-error {
  color: #fa5151;
  font-weight: bold;
}

.card {
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  background-color: #f8f9fa;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #eee;
  font-weight: bold;
  font-size: 32rpx;
}

.card-content {
  padding: 30rpx;
  color: #666;
  font-size: 28rpx;
}

.card-actions {
  padding: 0 30rpx 30rpx;
}

.card-actions button {
  width: 100%;
}

.instructions {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-weight: bold;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  color: #333;
}

.instruction-item {
  margin-bottom: 15rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: flex-start;
}

.instruction-item::before {
  content: "•";
  margin-right: 10rpx;
  color: #07c160;
  font-weight: bold;
}

.instruction-item:last-child {
  margin-bottom: 0;
}

/* 按钮样式 */
button[type="primary"] {
  background-color: #07c160 !important;
  border-color: #07c160 !important;
}

button {
  border-radius: 12rpx !important;
  font-size: 28rpx !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
}