/* pages/report/report.wxss */
.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.content-scroll {
  height: calc(100vh - env(safe-area-inset-bottom));
  padding-top: 0;
}

.page-header {
  padding: 20px 16px;
  background-color: #FFFFFF;
  border-bottom: 1px solid #EEEEEE;
}

.page-title {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8px;
}

.page-subtitle {
  font-size: 14px;
  color: #999999;
}

.reports-list {
  padding: 16px;
}

.report-item {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.report-title {
  flex: 1;
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  line-height: 1.4;
}

.report-tag {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
  margin-left: 8px;
}

.report-tag.macro {
  background-color: #E8F4FF;
  color: #1890FF;
}

.report-tag.industry {
  background-color: #F6FFED;
  color: #52C41A;
}

.report-tag.strategy {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.report-summary {
  font-size: 14px;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.report-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  border-top: 1px solid #F0F0F0;
}

.report-author,
.report-date {
  font-size: 12px;
  color: #999999;
}

.report-stats {
  display: flex;
  gap: 16px;
}

.stat {
  display: flex;
  align-items: center;
}

.stat-icon {
  width: 12px;
  height: 12px;
  margin-right: 4px;
}

.stat-number {
  font-size: 12px;
  color: #999999;
}

.load-more {
  text-align: center;
  padding: 20px;
}

.load-more-text {
  font-size: 14px;
  color: #C8102E;
}

.empty-state {
  text-align: center;
  padding: 60px 16px;
}

.empty-icon {
  width: 80px;
  height: 80px;
  margin-bottom: 16px;
  opacity: 0.4;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}