<!-- pages/activity/activity.wxml -->
<view class="page-container">
  
  <!-- 活动页面内容 -->
  <scroll-view class="content-scroll" scroll-y>
    <!-- 活动类型筛选 -->
    <view class="filter-section">
      <scroll-view class="filter-scroll" scroll-x>
        <block wx:for="{{filterTabs}}" wx:key="*this">
          <view 
            class="filter-tab {{activeFilter === item.value ? 'active' : ''}}" 
            data-value="{{item.value}}"
            bindtap="onFilterChange"
          >
            <text class="filter-text">{{item.label}}</text>
          </view>
        </block>
      </scroll-view>
    </view>
    
    <!-- 活动列表 -->
    <view class="activities-list">
      <block wx:for="{{activities}}" wx:key="id">
        <view class="activity-item" data-id="{{item.id}}" bindtap="onActivityTap">
          <image class="activity-cover" src="{{item.coverImage}}" mode="aspectFill"></image>
          
          <view class="activity-content">
            <view class="activity-header">
              <view class="activity-tags">
                <text class="activity-tag {{item.type === 'online' ? 'online-tag' : 'offline-tag'}}">
                  {{item.type === 'online' ? '线上' : '线下'}}
                </text>
                <text class="activity-tag category-tag">{{item.category}}</text>
              </view>
              <text class="activity-title">{{item.title}}</text>
              <text class="activity-description">{{item.description}}</text>
            </view>
            
            <view class="activity-footer">
              <view class="activity-info">
                <view class="info-item">
                  <image class="info-icon" src="https://api.iconify.design/mdi:calendar.svg?color=%23888888" mode="aspectFit"></image>
                  <text class="info-text">{{item.date}}</text>
                </view>
                <view class="info-item">
                  <image class="info-icon" src="https://api.iconify.design/mdi:map-marker.svg?color=%23888888" mode="aspectFit"></image>
                  <text class="info-text">{{item.location}}</text>
                </view>
              </view>
              
              <view class="activity-stats">
                <view class="stat-item">
                  <image class="stat-icon" src="https://api.iconify.design/mdi:account.svg?color=%23888888" mode="aspectFit"></image>
                  <text class="stat-text">{{item.participants}}人参与</text>
                </view>
                <view class="stat-item">
                  <image class="stat-icon" src="https://api.iconify.design/mdi:clock-outline.svg?color=%23888888" mode="aspectFit"></image>
                  <text class="stat-text">剩余{{item.daysLeft}}天</text>
                </view>
              </view>
              
              <button class="register-btn" data-id="{{item.id}}" bindtap="onRegisterTap" catchtap="stopPropagation">
                {{item.isRegistered ? '已报名' : '立即报名'}}
              </button>
            </view>
          </view>
        </view>
      </block>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{!loading && activities.length === 0}}" class="empty-state">
      <image class="empty-icon" src="https://api.iconify.design/mdi:inbox.svg?color=%23CCCCCC" mode="aspectFit"></image>
      <text class="empty-text">暂无活动</text>
    </view>
    
    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="onLoadMore">
      <text class="load-more-text">{{loading ? '加载中...' : '加载更多'}}</text>
    </view>
  </scroll-view>
</view>