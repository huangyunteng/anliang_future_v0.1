/* pages/search/search.wxss */
.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.search-container {
  padding-top: calc(44px + 20px); /* 导航栏高度 + 状态栏高度 */
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16px;
  background-color: #FFFFFF;
  border-bottom: 1px solid #EEEEEE;
}

.search-input-container {
  flex: 1;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 8px;
  padding: 8px 12px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(200, 16, 46, 0.08);
}

.search-icon {
  width: 16px;
  height: 16px;
  margin-right: 8px;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #333333;
  height: 20px;
  line-height: 20px;
}

.clear-btn {
  width: 16px;
  height: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  width: 100%;
  height: 100%;
  opacity: 0.4;
}

.search-cancel {
  font-size: 14px;
  color: #666666;
  margin-left: 12px;
}

.hot-search-section,
.search-history-section,
.search-result-section {
  background-color: #FFFFFF;
  padding: 20px 16px;
  margin-top: 12px;
}

.section-title {
  display: block;
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.hot-search-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.hot-search-tag {
  background-color: #F8F8F8;
  border-radius: 16px;
  padding: 8px 16px;
}

.tag-text {
  font-size: 14px;
  color: #666666;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.clear-history {
  width: 16px;
  height: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #F0F0F0;
}

.history-text {
  font-size: 14px;
  color: #666666;
}

.history-delete {
  width: 12px;
  height: 12px;
  opacity: 0.4;
}

.result-header {
  margin-bottom: 16px;
}

.result-count {
  font-size: 14px;
  color: #999999;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.result-item {
  background-color: #F8F8F8;
  border-radius: 12px;
  padding: 16px;
}

.result-type {
  display: inline-block;
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
  margin-bottom: 8px;
}

.result-type.report {
  background-color: #E8F4FF;
  color: #1890FF;
}

.result-type.article {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.result-type.event {
  background-color: #F6FFED;
  color: #52C41A;
}

.result-title {
  display: block;
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8px;
  line-height: 1.4;
}

.result-summary {
  display: block;
  font-size: 14px;
  color: #666666;
  line-height: 1.4;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.result-meta {
  display: flex;
  gap: 12px;
}

.meta-item {
  font-size: 12px;
  color: #999999;
}