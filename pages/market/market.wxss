/* 行情页面样式 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  font-size: 32rpx;
  padding: 10rpx;
}

/* 分类 Tab */
.category-tabs {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.tab-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
  margin: 0 4rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

/* 行情列表 */
.market-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.list-header {
  display: flex;
  padding: 20rpx;
  background: #f8f9fa;
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
}

.list-item {
  display: flex;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.list-item:last-child {
  border-bottom: none;
}

.col-symbol {
  width: 140rpx;
  font-weight: bold;
  color: #333;
}

.col-name {
  flex: 1;
  color: #666;
}

.col-price,
.col-change {
  width: 140rpx;
  text-align: right;
  font-weight: bold;
}

.up {
  color: #e74c3c;
}

.down {
  color: #27ae60;
}

/* 排行榜区块 */
.section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.rank-list {
  display: flex;
  flex-direction: column;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #666;
  margin-right: 20rpx;
}

.rank-item:nth-child(1) .rank-num {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.rank-item:nth-child(2) .rank-num {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.rank-item:nth-child(3) .rank-num {
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  color: white;
}

.rank-symbol {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
}

.rank-change {
  font-size: 28rpx;
  font-weight: bold;
}

/* 预警入口 */
.alert-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  color: white;
}

.alert-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.alert-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
}

.alert-arrow {
  font-size: 40rpx;
  opacity: 0.8;
}
